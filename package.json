{
  "name": "@gsknnft/skill-safe",
  "version": "0.2.1",
  "description": "Zero-dependency skill sanitizer — scans agent skill markdown for prompt injection, jailbreaks, data exfiltration, and other red flags before installation.",
  "keywords": [
    "agent-skills",
    "skill-sanitizer",
    "prompt-injection",
    "ai-safety",
    "markdown",
    "llm-security",
    "jailbreak-detection",
    "data-exfiltration",
    "vulnerability-scanner",
    "npm",
    "github",
    "cli",
    "types"
  ],
  "author": "gsknnft",
  "license": "MIT",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "skill-safe": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./rules": {
      "types": "./dist/rules.d.ts",
      "import": "./dist/rules.js",
      "default": "./dist/rules.js"
    },
    "./trust": {
      "types": "./dist/trust.d.ts",
      "import": "./dist/trust.js",
      "default": "./dist/trust.js"
    },
    "./resolver": {
      "types": "./dist/resolver.d.ts",
      "import": "./dist/resolver.js",
      "default": "./dist/resolver.js"
    },
    "./scanner": {
      "types": "./dist/scanner.d.ts",
      "import": "./dist/scanner.js",
      "default": "./dist/scanner.js"
    },
    "./sarif": {
      "types": "./dist/sarif.d.ts",
      "import": "./dist/sarif.js",
      "default": "./dist/sarif.js"
    },
    "./integrity": {
      "types": "./dist/integrity.d.ts",
      "import": "./dist/integrity.js",
      "default": "./dist/integrity.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "docs",
    "examples/README.md",
    "examples/full-report.mjs",
    "examples/fixtures",
    "examples/skills",
    "examples/reports/.gitkeep",
    "package.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gsknnft/skill-safe-core.git"
  },
  "homepage": "https://github.com/gsknnft/skill-safe-core#readme",
  "bugs": {
    "url": "https://github.com/gsknnft/skill-safe-core/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "pnpm clean && tsc -p tsconfig.build.json",
    "tsc:noemit": "tsc -b --noEmit",
    "test": "vitest run",
    "example:smoke": "pnpm build && node examples/full-report.mjs",
    "example:json": "pnpm build && node dist/cli.js --file examples/fixtures/malicious-skill.md --json --fail-on never",
    "example:markdown": "pnpm build && node dist/cli.js --file examples/fixtures/malicious-skill.md --full --fail-on never",
    "example:batch": "pnpm build && node dist/cli.js examples/skills --json --fail-on never",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "devDependencies": {
    "vitest": "4.0.18",
    "@vitest/coverage-v8": "4.0.18",
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3"
  }
}
